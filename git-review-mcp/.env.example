# ─── Provider selection ───────────────────────────────────────────────────────
# When both GitLab and GitHub are configured, GitLab takes precedence.
# Override explicitly with:
# GIT_PROVIDER=gitlab   # or github
GIT_PROVIDER=

# ─── GitLab ───────────────────────────────────────────────────────────────────
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=                          # Personal access token — needs "api" scope
GITLAB_USER=                           # Your GitLab username — used as default for git_list_my_reviews

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                          # Personal access token — needs "repo" scope
GITHUB_USER=                           # Your GitHub login — used as default for git_list_my_reviews
# For GitHub Enterprise, override the API base URL:
# GITHUB_URL=https://github.example.com/api/v3
GITHUB_URL=
